# AI/LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # Optional fallback

# Coordinator Delivery Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
COORDINATOR_CHANNELS=sms,email        # comma-separated: sms, email, whatsapp, telegram
COORDINATOR_DELIVERY_CHANNEL=sms      # Legacy fallback if COORDINATOR_CHANNELS is empty
COORDINATOR_PHONE=+1234567890         # Coordinator phone number for sms/whatsapp
COORDINATOR_EMAIL=coordinator@example.com
SMS_FROM=+1234567890                  # Your Twilio SMS number for coordinator delivery
WHATSAPP_FROM=whatsapp:+14155238886   # Your Twilio WhatsApp number if using whatsapp delivery
COORDINATOR_TO=+1234567890            # Legacy fallback for phone-based delivery

# Email Delivery Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true

# Telegram Delivery Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Application Configuration
SCHEDULE_TIME=09:00  # Daily check time (24-hour format)
TIMEZONE=America/New_York  # Your timezone
CSV_UPLOAD_PATH=./data/  # Path for CSV file uploads

# Supabase Database Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key  # Optional, for admin operations
SUPABASE_STORAGE_BUCKET

# Environment
ENVIRONMENT=development  # development, staging, production

# Optional: Backup/Logging
LOG_LEVEL=INFO
BACKUP_ENABLED=true

JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=

RATE_LIMIT_MAX_REQUESTS=
RATE_LIMIT_WINDOW_HOURS=

GROQ_MODEL=
OPENAI_MODEL=
